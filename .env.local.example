# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Cron Configuration
# Shared secret protecting /api/cron/* and /api/health/* routes. Vercel Cron
# sends this as `Authorization: Bearer ${CRON_SECRET}`. Generate a long random
# value (e.g. `openssl rand -hex 32`) and set it in the Vercel project env.
CRON_SECRET=your_cron_secret

# Error monitoring (Sentry). Optional — the app no-ops when these are unset.
# SENTRY_DSN is used server-side; NEXT_PUBLIC_SENTRY_DSN client-side (same value).
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=